{
  "DataSetIdentifierDeclarations": [
    {"Identifier": "variants", "DataSetArn": "arn:aws:quicksight:us-west-2:__AWS_ACCOUNT_ID__:dataset/hc-genomics-variants"}
  ],
  "Sheets": [{
    "SheetId": "sheet1",
    "Name": "Variant Overview",
    "Visuals": [
      {
        "KPIVisual": {
          "VisualId": "total-variants-kpi",
          "Title": {"Visibility": "VISIBLE", "FormatText": {"PlainText": "Total Variants Analyzed"}},
          "ChartConfiguration": {
            "FieldWells": {
              "Values": [{"NumericalMeasureField": {"FieldId": "total", "Column": {"DataSetIdentifier": "variants", "ColumnName": "VARIANT_COUNT"}, "AggregationFunction": {"SimpleNumericalAggregation": "SUM"}}}]
            }
          }
        }
      },
      {
        "BarChartVisual": {
          "VisualId": "pathogenic-by-gene",
          "Title": {"Visibility": "VISIBLE", "FormatText": {"PlainText": "Pathogenic Variant Count by Gene"}},
          "ChartConfiguration": {
            "FieldWells": {
              "BarChartAggregatedFieldWells": {
                "Category": [{"CategoricalDimensionField": {"FieldId": "gene", "Column": {"DataSetIdentifier": "variants", "ColumnName": "GENE"}}}],
                "Values": [{"NumericalMeasureField": {"FieldId": "pathogenic", "Column": {"DataSetIdentifier": "variants", "ColumnName": "PATHOGENIC_COUNT"}, "AggregationFunction": {"SimpleNumericalAggregation": "SUM"}}}]
              }
            },
            "SortConfiguration": {"CategorySort": [{"FieldSort": {"FieldId": "pathogenic", "Direction": "DESC"}}]}
          }
        }
      },
      {
        "BarChartVisual": {
          "VisualId": "cohort-comparison",
          "Title": {"Visibility": "VISIBLE", "FormatText": {"PlainText": "Pathogenic Variants by Cohort"}},
          "ChartConfiguration": {
            "FieldWells": {
              "BarChartAggregatedFieldWells": {
                "Category": [{"CategoricalDimensionField": {"FieldId": "gene2", "Column": {"DataSetIdentifier": "variants", "ColumnName": "GENE"}}}],
                "Values": [{"NumericalMeasureField": {"FieldId": "pathogenic2", "Column": {"DataSetIdentifier": "variants", "ColumnName": "PATHOGENIC_COUNT"}, "AggregationFunction": {"SimpleNumericalAggregation": "SUM"}}}],
                "Colors": [{"CategoricalDimensionField": {"FieldId": "cohort", "Column": {"DataSetIdentifier": "variants", "ColumnName": "COHORT_ID"}}}]
              }
            }
          }
        }
      }
    ],
    "Layouts": [{
      "Configuration": {
        "GridLayout": {
          "Elements": [
            {"ElementId": "total-variants-kpi", "ElementType": "VISUAL", "ColumnIndex": 0, "ColumnSpan": 12, "RowIndex": 0, "RowSpan": 4},
            {"ElementId": "pathogenic-by-gene", "ElementType": "VISUAL", "ColumnIndex": 0, "ColumnSpan": 18, "RowIndex": 4, "RowSpan": 10},
            {"ElementId": "cohort-comparison", "ElementType": "VISUAL", "ColumnIndex": 18, "ColumnSpan": 18, "RowIndex": 4, "RowSpan": 10}
          ]
        }
      }
    }]
  }]
}
